{
  "name": "viberail-ui",
  "version": "0.1.1",
  "description": "Interactive visual workbench for viberail specifications",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/mean-machine-gc/viberail-ui.git"
  },
  "homepage": "https://github.com/mean-machine-gc/viberail-ui#readme",
  "bugs": {
    "url": "https://github.com/mean-machine-gc/viberail-ui/issues"
  },
  "bin": {
    "viberail-ui": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "src/",
    "vite.config.ts",
    "tsconfig.json"
  ],
  "keywords": [
    "viberail",
    "specifications",
    "decision-table",
    "testing",
    "visualization",
    "workbench"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build && tsc --project tsconfig.cli.json",
    "dev": "VIBEGUARD_FOLDER=../mediator-example vite",
    "start": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@phosphor-icons/react": "^2.1.10",
    "glob": "^13.0.6",
    "viberail": "^0.1.0"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "cytoscape": "^3.32.0",
    "cytoscape-dagre": "^2.5.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
